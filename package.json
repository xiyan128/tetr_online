{
  "name": "tetr_online-web",
  "private": true,
  "type": "module",
  "scripts": {
    "build:wasm": "bun scripts/build.ts wasm --no-opt",
    "dev": "bun run build:wasm && bun --hot serve.ts",
    "serve": "bun --hot serve.ts",
    "build": "bun scripts/build.ts web",
    "build:embed": "bun scripts/build.ts embed --no-opt",
    "embedded-demo": "bun run build:embed && bun --hot serve-embed.ts",
    "embed:dist": "bun scripts/build.ts embed-dist"
  },
  "dependencies": {
    "preact": "^10.27.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5"
  }
}
