#!/usr/bin/env bash
# End-to-end smoke of the measurement loop, driven purely by registry
# names: the parse contract holds, the receipt + event stream land on disk,
# and unknown names are refused. Debug build, seconds. Run after touching
# the ledger / events / sprt / registry / bots plumbing.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

tr_run() { cargo run -q -p tetr-research -- "$@"; }
fail() { echo "research-smoke: FAIL — $*" >&2; exit 1; }

echo "== metric parse contract (smoke-downstack)"
METRIC_LOG=$(tr_run run smoke-downstack dt20 2>/dev/null) || fail "metric errored"
grep -q '^downstack_pieces_censored ' <<<"$METRIC_LOG" || fail "censored line missing"
grep -q '^downstack_clear_rate ' <<<"$METRIC_LOG" || fail "clear-rate line missing"

echo "== receipt + event stream (facts on disk, duckdb-ready)"
RUN_DIR=$(ls -td runs/*-smoke-downstack-* | head -1)
[[ -f "$RUN_DIR/spec.json" ]] || fail "receipt missing"
[[ -f "$RUN_DIR/events.jsonl" ]] || fail "event stream missing"
GAMES=$(grep -c '"kind":"game"' "$RUN_DIR/events.jsonl")
[[ "$GAMES" -eq 4 ]] || fail "want 4 game events, got $GAMES"
grep -q '"kind":"result"' "$RUN_DIR/events.jsonl" || fail "result event missing"

echo "== unknown names are refused (exit 2, never a silent default)"
set +e
tr_run run no-such-experiment dt20 >/dev/null 2>&1
CODE=$?
set -e
[[ "$CODE" -eq 2 ]] || fail "unknown name exited $CODE, want 2"

echo "research-smoke: PASS (first run $RUN_DIR)"
