#!/usr/bin/env bash
# End-to-end smoke of the agent research loop, driven purely by registry
# names: a tiny climb writes its receipt, stops at a cap,
# the promotion panel renders a verdict, the
# metric parse contract holds, and an unknown name is refused. Debug build,
# ~a minute. Run before unleashing autonomous campaigns and after touching
# the climb / ledger / sprt / registry / bots plumbing.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

tr_run() { cargo run -q -p tetr-research --bin tetr-research -- "$@"; }
tr_climb() { cargo run -q -p tetr-research --bin tetr-climb -- "$@"; }
fail() { echo "research-smoke: FAIL — $*" >&2; exit 1; }

echo "== climb (2 iters, tetr-climb climb smoke; rerun replaces resume)"
CLIMB_LOG=$(tr_climb climb smoke --max-iters 2 2>&1) ||
    fail "first climb run errored: $CLIMB_LOG"
RUN_DIR=$(ls -td runs/*-climb-smoke-* | head -1)
[[ -n "$RUN_DIR" ]] || fail "no climb receipt dir"
for f in spec.json; do
    [[ -f "$RUN_DIR/$f" ]] || fail "ledger artifact missing: $RUN_DIR/$f"
done
grep -q '"experiment": "climb-smoke"' "$RUN_DIR/spec.json" ||
    fail "experiment name not in spec.json"
grep -q '^best_params ' <<<"$CLIMB_LOG" || fail "no best_params line"

echo "== promotion panel (null check: smoke-panel must NOT promote)"
PROMOTE_LOG=$(tr_climb panel smoke attack-tuned-tiny 2>&1) || fail "promote errored: $PROMOTE_LOG"
grep -q '^panel_verdict REJECT' <<<"$PROMOTE_LOG" ||
    fail "null-check candidate was not rejected"

echo "== metric parse contract (smoke-downstack)"
METRIC_LOG=$(tr_run run smoke-downstack dt20 2>/dev/null) || fail "metric errored"
grep -q '^downstack_pieces_censored ' <<<"$METRIC_LOG" || fail "censored line missing"
grep -q '^downstack_clear_rate ' <<<"$METRIC_LOG" || fail "clear-rate line missing"

echo "== unknown names are refused (exit 2, never a silent default)"
set +e
tr_run run no-such-experiment dt20 >/dev/null 2>&1
CODE=$?
set -e
[[ "$CODE" -eq 2 ]] || fail "unknown name exited $CODE, want 2"

echo "research-smoke: PASS (first run $RUN_DIR)"
